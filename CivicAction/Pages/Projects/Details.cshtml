@page
@model CivicAction.Pages.Projects.DetailsModel
@using Microsoft.AspNetCore.Identity
@using CivicAction.Models
@inject UserManager<AppUser> UserManager

@{
    ViewData["Title"] = "Details";
    var currentUser = await UserManager.GetUserAsync(User);
    var isAdmin = currentUser?.IsAdmin == true;
}

<h1>Details</h1>

<div>
    <h4>Project</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Title)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Title)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Description)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Description)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Hours)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Hours)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Organization)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Organization)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Start)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Start)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.End)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.End)
        </dd>
        <dt class="col-sm-2">
            Status
        </dt>
        <dd class="col-sm-10">
            @if (Model.Project.IsApproved)
            {
                <span class="badge bg-success">Approved</span>
            }
            else if (Model.Project.Verifications != null && Model.Project.Verifications.Any(v => !v.IsApproved))
            {
                <span class="badge bg-danger">Denied</span>
            }
            else
            {
                <span class="badge bg-warning text-dark">Pending Review</span>
            }
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Project.Student)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Project.Student.FirstMidName) @Html.DisplayFor(model => model.Project.Student.LastName)
        </dd>
    </dl>
</div>

<div>
    <a asp-page="./Edit" asp-route-id="@Model.Project.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>

<hr />

@if (Model.Project.Verifications != null && Model.Project.Verifications.Any())
{
    <h4>Admin Feedback</h4>

    @foreach (var verification in Model.Project.Verifications)
    {
        <div class="card mb-2">
            <div class="card-body">
                <p>
                    <strong>Status:</strong>
                    @if (verification.IsApproved)
                    {
                        <span class="badge bg-success">Approved</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Denied</span>
                    }
                </p>
                <p>
                    <strong>Feedback:</strong>
                    @verification.Feedback
                </p>
            </div>
        </div>
    }

    <hr />
}

@if (isAdmin)
{
    <h4>Admin Review</h4>
    <div class="row">
        <div class="col-md-6">
            <form method="post" asp-page-handler="Review" asp-route-id="@Model.Project.Id">
                <div class="form-group">
                    <label asp-for="ReviewFeedback" class="control-label">Feedback</label>
                    <textarea asp-for="ReviewFeedback" class="form-control" rows="4"></textarea>
                </div>

                <div class="form-group mt-2">
                    <button type="submit" name="decision" value="approve" class="btn btn-success">Approve</button>
                    <button type="submit" name="decision" value="deny" class="btn btn-danger">Deny</button>
                </div>
            </form>
        </div>
    </div>

    <hr />
}

<h4>Hours Logged</h4>
<div class="row">
    <div class="col-md-8">
        @if (Model.Updates.Count == 0)
        {
            <p>No hours logged yet.</p>
        }
        else
        {
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th>Description</th>
                        <th>Hours Done</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var update in Model.Updates)
                    {
                        <tr>
                            <td>@update.Description</td>
                            <td>@update.HoursDone</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

<hr />

<h4>Log New Hours</h4>
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="NewUpdate.Description" class="control-label"></label>
                <textarea asp-for="NewUpdate.Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="NewUpdate.Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="NewUpdate.HoursDone" class="control-label"></label>
                <input asp-for="NewUpdate.HoursDone" class="form-control" type="number" step="0.5" />
                <span asp-validation-for="NewUpdate.HoursDone" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Log Hours" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}