@page
@model CivicAction.Pages.Projects.IndexModel

@{
    ViewData["Title"] = "My Projects";
}

<h1>My Projects</h1>
@if (Model.UserAccount != null)
{
    <p class="text-muted">Welcome, @Model.UserAccount.FirstMidName @Model.UserAccount.LastName</p>
}

<p>
    <a asp-page="Create">Create New</a>
</p>

@if (Model.Project != null && Model.Project.Count > 0)
{
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Project[0].Title)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Project[0].Description)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Project[0].Hours)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Project[0].Organization)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Project[0].IsApproved)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Project) {
        <tr>
            <td>
                <strong>@Html.DisplayFor(modelItem => item.Title)</strong>
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Description)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Hours) hrs
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Organization)
            </td>
            <td>
                @if (item.IsApproved)
                {
                    <span class="badge bg-success">Approved</span>
                }
                else
                {
                    <span class="badge bg-warning">Pending</span>
                }
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id" class="btn btn-sm btn-primary">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
}
else
{
    <div class="alert alert-info">
        <p>You don't have any projects yet. <a asp-page="Create">Create your first project</a></p>
    </div>
}
