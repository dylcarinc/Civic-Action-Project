@page
@model CivicAction.Pages.Projects.IndexModel
@{
    ViewData["Title"] = "Projects";
    var isAdmin = HttpContext.Session.GetString("IsAdmin") == "True";
}

<h1>Projects</h1>

@if (!isAdmin)
{
    <p><a asp-page="Create">Add New Project</a></p>
}

<table class="table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Organization</th>
            <th>Hours</th>
            <th>Start</th>
            <th>End</th>
            @if (isAdmin)
            {
                <th>Student</th>
            }
            <th>Status</th>
            <th>Review</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var project in Model.Projects)
        {
            <tr>
                <td>@project.Title</td>
                <td>@project.Organization</td>
                <td>@project.Hours</td>
                <td>@project.Start</td>
                <td>@project.End</td>
                @if (isAdmin)
                {
                    <td>@project.Student?.FirstMidName @project.Student?.LastName</td>
                }
                <td>
                    @if (project.IsApproved)
                    {
                        <span class="badge bg-success">Approved</span>
                    }
                    else if (project.Verifications != null && project.Verifications.Any(v => !v.IsApproved))
                    {
                        <span class="badge bg-danger">Denied</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pending Review</span>
                    }
                </td>
                <td>
                    <a asp-page="./Details" asp-route-id="@project.Id">Details</a>
                </td>
            </tr>
        }
    </tbody>
</table>