@page
@model CivicAction.Pages.Volunteer.DetailsModel

@{
    ViewData["Title"] = "Volunteer Organization";
}

<h1>@Model.Organization.Name</h1>

<p>
    <a asp-page="./Index">Back to Volunteer Hours</a>
</p>

<p><strong>Total Hours:</strong> @Model.Organization.VolunteerHours.Sum(h => h.Hours)</p>

<hr />

<h4>Hours Logged</h4>

@if (Model.Organization.VolunteerHours.Count == 0)
{
    <p>No hours have been logged for this organization yet.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Date</th>
                <th>Hours</th>
                <th>Work Completed</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var hour in Model.Organization.VolunteerHours.OrderByDescending(h => h.WorkDate))
            {
                <tr>
                    <td>@hour.WorkDate.ToShortDateString()</td>
                    <td>@hour.Hours</td>
                    <td>@hour.WorkDescription</td>
                </tr>
            }
        </tbody>
    </table>
}

<hr />

<h4>Log New Hours</h4>

<div class="row">
    <div class="col-md-5">
        <form method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="NewHour.WorkDate" class="control-label">Date</label>
                <input asp-for="NewHour.WorkDate" class="form-control" type="date" />
                <span asp-validation-for="NewHour.WorkDate" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NewHour.Hours" class="control-label">Hours</label>
                <input asp-for="NewHour.Hours" class="form-control" type="number" step="0.5" />
                <span asp-validation-for="NewHour.Hours" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="NewHour.WorkDescription" class="control-label">Work Completed</label>
                <textarea asp-for="NewHour.WorkDescription" class="form-control" rows="3"></textarea>
                <span asp-validation-for="NewHour.WorkDescription" class="text-danger"></span>
            </div>

            <div class="form-group mt-2">
                <input type="submit" value="Add Hours" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}