@page
@model IndexModel

@{
    ViewData["Title"] = "Home";
}

<div class="container">
    <div class="row align-items-center justify-content-center" style="min-height: 80vh;">
        <div class="col-lg-8 text-center">
            <h1 class="display-4">Welcome to Arkansas Civic Action Network</h1>
            <p class="lead">Empowering students to make a difference in their communities</p>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <p>
                    <a class="btn btn-primary btn-lg" asp-page="/Projects/Index">View Projects</a>
                </p>
            }
            else
            {
                <p>
                    <a class="btn btn-primary btn-lg" asp-area="Identity" asp-page="/Account/Login">Login</a>
                </p>
            }
        </div>
    </div>
</div>
