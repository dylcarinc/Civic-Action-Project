@page
@model CivicAction.Pages.Updates.CreateModel

@{
    ViewData["Title"] = "Log Hours";
}

<h1>Log Hours</h1>

<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="form-group">
                <label asp-for="Update.Description" class="control-label"></label>
                <input asp-for="Update.Description" class="form-control" />
                <span asp-validation-for="Update.Description" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Update.HoursDone" class="control-label"></label>
                <input asp-for="Update.HoursDone" class="form-control" />
                <span asp-validation-for="Update.HoursDone" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <label asp-for="Update.ProjectID" class="control-label"></label>
                <select asp-for="Update.ProjectID" class="form-control" asp-items="ViewBag.ProjectID"></select>
                <span asp-validation-for="Update.ProjectID" class="text-danger"></span>
            </div>
            
            <div class="form-group">
                <input type="submit" value="Log Hours" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
