@page
@model CivicAction.Pages.Accounts.DetailsModel

@{
    ViewData["Title"] = "Student Details";
}

<h1>Student Details</h1>

<div>
    <h4>@Model.Account.FirstMidName @Model.Account.LastName</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">Email</dt>
        <dd class="col-sm-10">@Model.Account.Email</dd>

        <dt class="col-sm-2">Grade</dt>
        <dd class="col-sm-10">@Model.Account.Grade</dd>

        <dt class="col-sm-2">School</dt>
        <dd class="col-sm-10">@Model.Account.School</dd>

        <dt class="col-sm-2">Total Projects</dt>
        <dd class="col-sm-10">@Model.Account.Projects.Count</dd>

        <dt class="col-sm-2">Total Volunteer Hours</dt>
        <dd class="col-sm-10">@Model.Account.VolunteerOrganizations.SelectMany(o => o.VolunteerHours).Sum(h => h.Hours)</dd>

        <dt class="col-sm-2">Volunteer Organizations</dt>
        <dd class="col-sm-10">
            @string.Join(", ", Model.Account.VolunteerOrganizations.Select(o => o.Name).Distinct())
        </dd>
    </dl>
</div>

<hr />

<h4>Volunteer Hours</h4>

@if (Model.Account.VolunteerOrganizations.Count == 0)
{
    <p>This student has not logged any volunteer organizations yet.</p>
}
else
{
    @foreach (var organization in Model.Account.VolunteerOrganizations)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@organization.Name</h5>
                <p><strong>Total Hours:</strong> @organization.VolunteerHours.Sum(h => h.Hours)</p>

                @if (organization.VolunteerHours.Count == 0)
                {
                    <p>No hours logged for this organization.</p>
                }
                else
                {
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Hours</th>
                                <th>Work Completed</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var hour in organization.VolunteerHours.OrderByDescending(h => h.WorkDate))
                            {
                                <tr>
                                    <td>@hour.WorkDate.ToShortDateString()</td>
                                    <td>@hour.Hours</td>
                                    <td>@hour.WorkDescription</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    }
}

<hr />

<h4>Projects</h4>

@if (Model.Account.Projects.Count == 0)
{
    <p>This student does not have any projects yet.</p>
}
else
{
    @foreach (var project in Model.Account.Projects)
    {
        <div class="card mb-3">
            <div class="card-body">
                <h5 class="card-title">@project.Title</h5>

                <p><strong>Description:</strong> @project.Description</p>
                <p><strong>Organization:</strong> @project.Organization</p>
                <p><strong>Required Hours:</strong> @project.Hours</p>
                <p><strong>Start:</strong> @project.Start</p>
                <p><strong>End:</strong> @project.End</p>

                <p>
                    <strong>Status:</strong>
                    @if (project.IsApproved)
                    {
                        <span class="badge bg-success">Approved</span>
                    }
                    else if (project.Verifications != null && project.Verifications.Any(v => !v.IsApproved))
                    {
                        <span class="badge bg-danger">Denied</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Pending Review</span>
                    }
                </p>
            </div>
        </div>
    }
}

<div>
    <a asp-page="./Index">Back to Student Search</a>
</div>