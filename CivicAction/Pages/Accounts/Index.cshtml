@page
@model CivicAction.Pages.Accounts.IndexModel

@{
    ViewData["Title"] = "Student Search";
}

<h1>Student Search</h1>

<form method="get">
    <div class="form-group">
        <label asp-for="SearchTerm" class="control-label">Search by student name</label>
        <input asp-for="SearchTerm" class="form-control" />
    </div>

    <div class="form-group mt-2">
        <input type="submit" value="Search" class="btn btn-primary" />
        <a asp-page="./Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<hr />

@if (Model.Account.Count == 0)
{
    <p>No students found.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Student</th>
                <th>Email</th>
                <th>Grade</th>
                <th>School</th>
                <th>Projects</th>
                <th>Total Volunteer Hours</th>
                <th>Volunteer Organizations</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Account)
            {
                <tr>
                    <td>
                        <a asp-page="./Details" asp-route-id="@item.Id">
                            @item.FirstMidName @item.LastName
                        </a>
                    </td>
                    <td>@item.Email</td>
                    <td>@item.Grade</td>
                    <td>@item.School</td>
                    <td>@item.Projects.Count</td>
                    <td>@item.VolunteerOrganizations.SelectMany(o => o.VolunteerHours).Sum(h => h.Hours)</td>
                    <td>
                        @if (item.VolunteerOrganizations.Count == 0)
                        {
                            <span>No organizations yet</span>
                        }
                        else
                        {
                            @string.Join(", ", item.VolunteerOrganizations.Select(o => o.Name).Distinct())
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}